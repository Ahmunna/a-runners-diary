# Copy to .env and fill in. docker-compose reads these for the web service.

# From your Strava API application: https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Any random string you choose — used to validate Strava's webhook handshake.
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Generate once with: bin/rails runner "k = WebPush.generate_key; puts k.public_key; puts k.private_key"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
