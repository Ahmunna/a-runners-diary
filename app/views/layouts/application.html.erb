<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "A Runner's Diary" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-title" content="Runner's Diary">
    <meta name="theme-color" content="#0f1f30">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-navy-50 text-navy-900">
    <% if user_signed_in? %>
      <header class="bg-navy-900 text-white">
        <nav class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
          <%= link_to root_path, class: "flex items-center gap-2 font-semibold text-white" do %>
            <svg class="w-6 h-6 text-navy-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 4l-2.5 2.5M13 4l3 3-1.5 1.5M13 4l2 2M4 20l4.5-4.5a3 3 0 0 1 1-.6l3-1 2-2 2.5 2.5-2 2-1 3a3 3 0 0 1-.6 1L9 21" /><circle cx="17.5" cy="6.5" r="1.5" /></svg>
            <span>A Runner's Diary</span>
          <% end %>
          <div class="flex items-center gap-1 sm:gap-2 text-sm">
            <%= link_to "Dashboard", dashboard_path, class: "nav-link px-3 py-2 rounded-md #{'bg-navy-800 text-white' if current_page?(dashboard_path)}" %>
            <%= link_to "Nutrition", nutrition_logs_path, class: "nav-link px-3 py-2 rounded-md #{'bg-navy-800 text-white' if controller_name == 'nutrition_logs'}" %>
            <%= link_to "Coach chat", messages_path, class: "nav-link px-3 py-2 rounded-md #{'bg-navy-800 text-white' if controller_name == 'messages'}" %>
            <%= link_to "Settings", edit_claude_credential_path, class: "nav-link px-3 py-2 rounded-md #{'bg-navy-800 text-white' if controller_name == 'claude_credentials'}" %>
            <% if current_user.admin? %>
              <%= link_to "Admin", admin_users_path, class: "nav-link px-3 py-2 rounded-md text-amber-300 hover:text-amber-200 #{'bg-navy-800' if controller_name == 'admin/users'}" %>
            <% end %>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "nav-link px-3 py-2 rounded-md bg-transparent border-0 cursor-pointer" %>
          </div>
        </nav>
      </header>

      <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
        <% if notice %>
          <div class="banner-success mb-6"><span><%= notice %></span></div>
        <% end %>
        <% if alert %>
          <div class="banner-error mb-6"><span><%= alert %></span></div>
        <% end %>

        <%= yield %>
      </main>
    <% else %>
      <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-navy-950 via-navy-900 to-navy-700 px-4 py-12">
        <div class="w-full max-w-md">
          <div class="flex items-center justify-center gap-2 mb-8 text-white">
            <svg class="w-7 h-7 text-navy-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 4l-2.5 2.5M13 4l3 3-1.5 1.5M13 4l2 2M4 20l4.5-4.5a3 3 0 0 1 1-.6l3-1 2-2 2.5 2.5-2 2-1 3a3 3 0 0 1-.6 1L9 21" /><circle cx="17.5" cy="6.5" r="1.5" /></svg>
            <span class="font-semibold text-lg">A Runner's Diary</span>
          </div>

          <div class="card">
            <% if notice %>
              <div class="banner-success mb-5"><span><%= notice %></span></div>
            <% end %>
            <% if alert %>
              <div class="banner-error mb-5"><span><%= alert %></span></div>
            <% end %>

            <%= yield %>
          </div>
        </div>
      </div>
    <% end %>
  </body>
</html>
