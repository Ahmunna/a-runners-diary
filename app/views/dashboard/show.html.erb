<% content_for :title, "Dashboard" %>

<div class="flex flex-wrap items-end justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-bold mb-1">Hey <%= current_user.first_name %></h1>
    <% if @race %>
      <p class="text-navy-500">
        <%= @race.distance_label %> · <%= @race.race_date %>
        <% if @race.time_objective.present? %> · target <%= @race.time_objective %><% end %>
      </p>
    <% end %>
  </div>
  <% if @race %>
    <div class="flex items-center gap-2">
      <span class="badge-info"><%= @race.difficulty.humanize %></span>
      <span class="badge-neutral"><%= pluralize((( @race.race_date - Date.current ).to_i), "day") %> to go</span>
    </div>
  <% end %>
</div>

<div class="space-y-3 mb-6">
  <% if current_user.strava_connection.blank? %>
    <div class="banner-warning">
      <span>Connect Strava first so your coach can see your real training before generating a plan.</span>
      <%= link_to "Connect Strava", strava_connect_path, class: "btn-secondary shrink-0" %>
    </div>
  <% elsif current_user.claude_credential.blank? %>
    <div class="banner-warning">
      <span>Strava connected. Now add your Claude API key to generate your training program.</span>
      <%= link_to "Add key", new_claude_credential_path, class: "btn-secondary shrink-0" %>
    </div>
  <% end %>

  <% if current_user.race && @program.nil? && current_user.claude_credential %>
    <div class="banner-info" data-controller="auto-refresh">
      <span>Your training program is being generated by Claude — this page will update automatically.</span>
    </div>
  <% end %>
</div>

<%= render "shared/notification_setup" %>

<% if @current_week %>
  <%= link_to roadmap_path, class: "card mb-6 flex flex-wrap items-center justify-between gap-3 hover:border-navy-300 transition-colors" do %>
    <div class="flex items-center gap-3">
      <span class="<%= @current_week.badge_class %>"><%= @current_week.phase_label %></span>
      <span class="text-sm text-navy-700">Week <%= @current_week.week_number %> of <%= @total_weeks %> · <%= @current_week.target_distance_km %>km target</span>
    </div>
    <span class="text-sm text-navy-500 hover:text-navy-700 inline-flex items-center gap-1">
      View full roadmap
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </span>
  <% end %>
<% end %>

<div class="grid md:grid-cols-2 gap-5">
  <section class="card">
    <div class="flex items-center gap-2 mb-3">
      <svg class="w-5 h-5 text-navy-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
      <h2 class="font-semibold">Today's training</h2>
    </div>
    <% if @today %>
      <p class="text-xs text-navy-400 mb-2"><%= @today.date %> · <span class="badge-<%= @today.status == 'completed' ? 'success' : (@today.status == 'skipped' ? 'warning' : 'info') %>"><%= @today.status.humanize %></span></p>
      <p class="text-navy-800"><%= @today.workout %></p>
    <% else %>
      <p class="text-navy-400 text-sm">Nothing scheduled for today yet.</p>
    <% end %>
  </section>

  <section class="card">
    <div class="flex items-center gap-2 mb-3">
      <svg class="w-5 h-5 text-navy-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
      <h2 class="font-semibold">Coach's take</h2>
    </div>
    <% if @program&.claude_summary.present? %>
      <p class="text-navy-800 whitespace-pre-wrap"><%= @program.claude_summary %></p>
    <% else %>
      <p class="text-navy-400 text-sm">No coach summary yet.</p>
    <% end %>
  </section>

  <section class="card">
    <div class="flex items-center gap-2 mb-3">
      <svg class="w-5 h-5 text-navy-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4z" /><path d="M6 1v3M10 1v3M14 1v3" /></svg>
      <h2 class="font-semibold">Today's nutrition</h2>
    </div>
    <% if @nutrition_log %>
      <p class="text-navy-800 mb-2"><%= @nutrition_log.calories %> kcal · P<%= @nutrition_log.protein_g %>/C<%= @nutrition_log.carbs_g %>/F<%= @nutrition_log.fat_g %></p>
      <%= link_to "Edit", edit_nutrition_log_path(@nutrition_log), class: "text-navy-600 hover:underline text-sm font-medium" %>
    <% else %>
      <p class="text-navy-400 text-sm mb-3">Nothing logged today.</p>
      <%= link_to "Log today's meals", new_nutrition_log_path, class: "text-navy-600 hover:underline text-sm font-medium" %>
    <% end %>
  </section>

  <section class="card">
    <div class="flex items-center gap-2 mb-3">
      <svg class="w-5 h-5 text-navy-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9z" /></svg>
      <h2 class="font-semibold">Recent activities</h2>
    </div>
    <% if @recent_activities.any? %>
      <ul class="text-sm text-navy-800 space-y-1.5">
        <% @recent_activities.each do |a| %>
          <li class="flex justify-between"><span><%= a.occurred_at&.to_date %></span><span class="text-navy-500"><%= a.distance_km %>km · <%= a.duration_minutes %>min</span></li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-navy-400 text-sm">No Strava activity synced yet.</p>
    <% end %>
  </section>
</div>

<div class="mt-6 flex flex-wrap gap-3">
  <%= link_to messages_path, class: "btn-secondary" do %>
    Talk to your coach
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
  <% end %>

  <% if current_user.strava_connection %>
    <%= button_to strava_sync_path, method: :post, class: "btn-ghost" do %>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-2.64-6.36M21 4v5h-5" /></svg>
      Check for updates
    <% end %>
  <% end %>
</div>
