<% content_for :title, "Set your race goal" %>

<div class="max-w-xl mx-auto">
  <div class="flex items-center gap-2 text-xs font-medium text-navy-400 mb-3">
    <span class="text-emerald-600">✓ Profile</span>
    <span>·</span>
    <span class="text-navy-700">Step 2 of 2 — Race goal</span>
  </div>

  <h1 class="text-2xl font-bold mb-1">Set your race goal</h1>
  <p class="text-navy-500 mb-6">One active goal at a time. You can change it later from settings.</p>

  <div class="card">
    <%= form_with model: @race, url: onboarding_race_path, method: :post, class: "space-y-5" do |f| %>
      <% if @race.errors.any? %>
        <div class="field-error">
          <ul class="list-disc pl-5">
            <% @race.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :race_type, "Race distance", class: "field-label" %>
        <%= f.select :race_type, Race::TYPES.map { |t| [t.humanize, t] }, { prompt: "Select" }, class: "field-input" %>
      </div>

      <div>
        <%= f.label :race_date, class: "field-label" %>
        <%= f.date_field :race_date, class: "field-input" %>
      </div>

      <div>
        <%= f.label :time_objective, "Target time (hh:mm:ss)", class: "field-label" %>
        <%= f.text_field :time_objective, placeholder: "01:50:00", class: "field-input" %>
      </div>

      <div>
        <%= f.label :difficulty, class: "field-label" %>
        <%= f.select :difficulty, Race::DIFFICULTIES.map { |d| [d.humanize, d] }, { prompt: "Select" }, class: "field-input" %>
        <p class="field-hint">Advanced means high volume (5-6 sessions/week) and a demanding tone from your coach.</p>
      </div>

      <%= f.submit "Continue", class: "btn-primary w-full" %>
    <% end %>
  </div>
</div>
