<% content_for :title, "Roadmap" %>

<h1 class="text-2xl font-bold mb-1">Race roadmap</h1>
<% if @race %>
  <p class="text-navy-500 mb-6">
    <%= @race.distance_label %> on <%= @race.race_date.strftime("%B %-d, %Y") %>
    <% if @weeks.any? %> · <%= pluralize(@weeks.count, "week") %> planned<% end %>
  </p>
<% end %>

<% if @program.nil? %>
  <div class="card text-center py-12">
    <p class="text-navy-500">No active program yet — your roadmap will appear here once your coach generates your plan.</p>
    <%= link_to "Back to dashboard", dashboard_path, class: "btn-primary mt-4 inline-flex" %>
  </div>
<% elsif @weeks.empty? %>
  <div class="card text-center py-12">
    <p class="text-navy-500">No roadmap yet — check back in a moment, or tap "Check for updates" on your dashboard.</p>
  </div>
<% else %>
  <div class="space-y-3">
    <% @weeks.each do |week| %>
      <div class="card flex items-center gap-4 <%= 'ring-2 ring-navy-800' if week.current? %>">
        <div class="text-center shrink-0 w-14">
          <p class="text-xs text-navy-400">Week</p>
          <p class="text-xl font-bold text-navy-900"><%= week.week_number %></p>
        </div>

        <div class="flex-1 min-w-0">
          <div class="flex flex-wrap items-center gap-2 mb-1">
            <span class="<%= week.badge_class %>"><%= week.phase_label %></span>
            <% if week.current? %><span class="text-xs font-medium text-navy-600">Current week</span><% end %>
          </div>
          <p class="text-sm text-navy-500"><%= week.start_date.strftime("%b %-d") %> – <%= week.end_date.strftime("%b %-d") %></p>
          <p class="text-sm text-navy-700 mt-1"><%= week.focus %></p>
        </div>

        <div class="text-right shrink-0">
          <p class="text-lg font-semibold text-navy-900"><%= week.target_distance_km %>km</p>
          <p class="text-xs text-navy-400">target</p>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
