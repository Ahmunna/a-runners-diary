<% content_for :title, "Nutrition" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">Nutrition logs</h1>
  <%= link_to "Log today", new_nutrition_log_path, class: "btn-primary" %>
</div>

<% if @nutrition_logs.empty? %>
  <div class="card text-center py-12">
    <p class="text-navy-500">No logs yet. Logging your meals gives Claude more context to adjust your plan.</p>
    <%= link_to "Log today's meals", new_nutrition_log_path, class: "btn-primary mt-4 inline-flex" %>
  </div>
<% else %>
  <div class="card !p-0 overflow-x-auto">
    <table class="table-clean min-w-[640px]">
      <thead>
        <tr>
          <th class="px-5">Date</th>
          <th>Calories</th>
          <th>Protein</th>
          <th>Carbs</th>
          <th>Fat</th>
          <th>Notes</th>
          <th class="px-5"></th>
        </tr>
      </thead>
      <tbody>
        <% @nutrition_logs.each do |log| %>
          <tr>
            <td class="px-5 font-medium"><%= log.date %></td>
            <td><%= log.calories %> kcal</td>
            <td><%= log.protein_g %>g</td>
            <td><%= log.carbs_g %>g</td>
            <td><%= log.fat_g %>g</td>
            <td class="text-navy-500"><%= truncate(log.notes, length: 40) %></td>
            <td class="px-5"><%= link_to "Edit", edit_nutrition_log_path(log), class: "text-navy-600 hover:underline font-medium" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
